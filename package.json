{
  "name": "conexor-local-agent",
  "version": "2.0.0",
  "description": "Conexor Local Agent - Agente multiplataforma para integração local",
  "main": "agent.js",
  "scripts": {
    "start": "node agent.js",
    "dev": "nodemon agent.js",
    "build": "npm run build-all",
    "build-all": "pkg agent.js --targets node18-win-x64,node18-macos-x64,node18-linux-x64 --out-path dist",
    "build-win": "pkg agent.js --targets node18-win-x64 --out-path dist",
    "build-mac": "pkg agent.js --targets node18-macos-x64 --out-path dist",
    "build-linux": "pkg agent.js --targets node18-linux-x64 --out-path dist",
    "build-win32": "pkg agent.js --targets node18-win-x86 --out-path dist",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "iconv-lite": "^0.7.0",
    "usb": "^2.9.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "pkg": "^5.8.1"
  },
  "pkg": {
    "assets": [
      "node_modules/usb/**/*"
    ],
    "targets": [
      "node18-win-x64",
      "node18-macos-x64",
      "node18-linux-x64"
    ]
  },
  "author": "Alcélio Gomes - Conexor",
  "license": "MIT"
}
